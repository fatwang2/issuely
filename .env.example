# Required: Linear OAuth App credentials
# Create at: https://linear.app/settings/api/applications
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SIGNING_SECRET=

# Required: Public URL for webhooks (Cloudflare Tunnel)
BASE_URL=https://kanban-bridge.yourdomain.com

# Optional: Server port (default: 3010)
PORT=3010

# Optional: Linear API URLs (defaults shown)
# LINEAR_URL=https://linear.app
# LINEAR_API_URL=https://api.linear.app

# Optional: Project directory mapping
# Format: KEY=/path/to/repo,KEY=/path/to/repo
# KEY is matched (case-insensitive) against the Linear issue's
# projectId, projectName, teamId, teamKey, or teamName — whichever hits
# first wins. Most intuitive keys: team key (e.g. FAT) or project name.
# PROJECT_DIRS=FAT=/Users/you/repos/main,DesignSystem=/Users/you/repos/ds

# Optional: Default working directory for agents
# DEFAULT_WORK_DIR=/path/to/default/repo

# Optional: Agent configuration
# DEFAULT_AGENT=claude-code
# CLAUDE_CODE_PATH=claude
# CLAUDE_CODE_MODEL=
# CLAUDE_CODE_MAX_TURNS=
# Permission mode: default | acceptEdits | plan | bypassPermissions
# Defaults to bypassPermissions (non-interactive, skips all permission prompts).
# CLAUDE_CODE_PERMISSION_MODE=bypassPermissions

# Optional: Dispatcher settings
# MAX_CONCURRENT=1
# TIMEOUT_MS=480000               # per-task hard timeout (ms), default 8 min
# PROGRESS_THROTTLE_MS=5000       # min ms between progress updates per task

# Optional: Log level (debug, info, warn, error)
# LOG_LEVEL=info
